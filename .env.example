# Xiaomi Mimo Proxy Configuration

# Port to listen on
PORT=3000

# Optional: API Key to protect your proxy
# API_KEY=your_secret_key

# Single Account Configuration
SERVICE_TOKEN="seu_service_token_aqui"
USER_ID="seu_user_id_aqui"
XIAOMI_CHATBOT_PH="seu_ph_aqui"

# Multiple Account Configuration (Optional - replaces single account)
# Use comma-separated values for rotation
# SERVICE_TOKENS="token1,token2,token3"
# USER_IDS="id1,id2,id3"
# XIAOMI_CHATBOT_PHS="ph1,ph2,ph3"
